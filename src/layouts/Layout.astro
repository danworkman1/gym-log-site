---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Gym Log - Simple, effective workout tracking." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
		<title>{title} | Gym Log</title>
		<meta name="description" content={description} />
		<style is:global>
			:root {
				--bg: #fffdfa;
				--surface: #ffffff;
				--primary: #f59e0b;
				--primary-dark: #b45309;
				--secondary: #fbbf24;
				--text: #451a03;
				--text-muted: #92400e;
				--border: #fde68a;
				--success: #059669;
				--glass: rgba(255, 255, 255, 0.9);
			}

			* {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			html,
			body {
				width: 100%;
				min-height: 100vh;
				font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
				background-color: var(--bg);
				color: var(--text);
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
			}

			body {
				display: flex;
				flex-direction: column;
			}

			header {
				position: sticky;
				top: 0;
				z-index: 50;
				background: var(--glass);
				backdrop-filter: blur(12px);
				border-bottom: 1px solid var(--border);
				padding: 1rem 0;
			}

			nav {
				display: flex;
				justify-content: space-between;
				align-items: center;
				max-width: 1240px;
				margin: 0 auto;
				padding: 0 1.5rem;
			}

			.logo {
				display: flex;
				align-items: center;
				text-decoration: none;
			}

			.logo img {
				height: 2.25rem;
				width: auto;
				display: block;
			}

			@media (min-width: 640px) {
				.logo img {
					height: 3rem;
				}
			}

			.nav-links {
				display: flex;
				gap: 2rem;
			}

			nav a {
				text-decoration: none;
				color: var(--text-muted);
				font-weight: 500;
				transition: color 0.2s;
				font-size: 0.95rem;
			}

			nav a:hover {
				color: var(--primary-dark);
			}

			main {
				flex: 1;
				max-width: 1240px;
				width: 100%;
				margin: 0 auto;
				padding: 3rem 1.5rem;
			}

			footer {
				margin-top: auto;
				padding: 3rem 1.5rem;
				border-top: 1px solid var(--border);
				text-align: center;
				color: var(--text-muted);
				font-size: 0.875rem;
				background-color: var(--surface);
			}

			h1, h2, h3 {
				color: var(--primary-dark);
				font-weight: 800;
				line-height: 1.2;
				margin-bottom: 1rem;
			}

			h1 { font-size: 3rem; letter-spacing: -0.04em; }
			h2 { font-size: 2.25rem; letter-spacing: -0.03em; }
			h3 { font-size: 1.25rem; }

			.btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				background: var(--primary);
				color: white;
				padding: 0.75rem 1.75rem;
				border-radius: 0.75rem;
				text-decoration: none;
				font-weight: 700;
				transition: all 0.2s;
				box-shadow: 0 4px 6px -1px rgba(180, 83, 9, 0.1), 0 2px 4px -1px rgba(180, 83, 9, 0.06);
				border: none;
				cursor: pointer;
			}

			.btn:hover {
				background: var(--primary-dark);
				transform: translateY(-1px);
				box-shadow: 0 10px 15px -3px rgba(180, 83, 9, 0.2);
			}

			.btn:active {
				transform: translateY(0);
			}

			p {
				margin-bottom: 1.5rem;
				color: var(--text-muted);
			}

			strong {
				color: var(--text);
			}
		</style>
	</head>
	<body>
		<header>
			<nav>
				<a href="/" class="logo">
					<img src="/logo.png" alt="Gym Log" />
				</a>
				<div class="nav-links">
					<a href="/support">Support</a>
					<a href="/privacy">Privacy</a>
					<a href="/contact">Contact</a>
				</div>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer>
			&copy; {new Date().getFullYear()} Gym Log. Built for lifters, by lifters.
		</footer>
	</body>
</html>
