---
import Layout from '../layouts/Layout.astro';

const appStoreUrl = 'https://apps.apple.com/au/app/gym-log-strength-journal/id6766238867';
---

<Layout title="Home" description="The simplest way to log your workouts and stay consistent.">
	<section class="hero">
		<div class="hero-content">
			<img src="/logo.png" alt="" class="hero-logo" width="180" height="180" />
			<h1 class="gradient-text">Gym Log</h1>
			<p class="subtitle">Focus on your gains, not your screen.</p>
			<p class="description">Gym Log is a clean, minimal workout tracker built for lifters who want to spend more time lifting and less time tapping.</p>
			<div class="cta">
				<a href={appStoreUrl} class="btn appstore-btn" target="_blank" rel="noopener">
					<svg class="apple-logo" width="18" height="18" viewBox="0 0 384 512" aria-hidden="true" focusable="false"><path fill="currentColor" d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>
					Download on the App Store
				</a>
			</div>
		</div>
		<div class="hero-glow"></div>
	</section>

	<section class="features">
		<div class="section-header">
			<h2>Features</h2>
			<div class="divider"></div>
		</div>
		<div class="feature-grid">
			<div class="feature-card">
				<div class="icon">📝</div>
				<h3>Simple Logging</h3>
				<p>Quickly add exercises, sets, and reps without the friction of complex interfaces.</p>
			</div>
<div class="feature-card">
				<div class="icon">📈</div>
				<h3>Progress Tracking</h3>
				<p>Visualize your journey with detailed history and personal record tracking.</p>
			</div>
			<div class="feature-card">
				<div class="icon">🛡️</div>
				<h3>Privacy First</h3>
				<p>Your data stays on your device and in your personal iCloud account. No tracking.</p>
			</div>
		</div>
	</section>

	<section class="download" id="download">
		<div class="download-card">
			<div class="download-text">
				<h2>Get the App</h2>
				<div class="divider"></div>
				<p>Gym Log is live on the App Store. Download it on your iPhone and start logging your lifts today.</p>
				<a href={appStoreUrl} class="btn appstore-btn" target="_blank" rel="noopener">
					<svg class="apple-logo" width="18" height="18" viewBox="0 0 384 512" aria-hidden="true" focusable="false"><path fill="currentColor" d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>
					Download on the App Store
				</a>
			</div>
			<a class="qr" href={appStoreUrl} target="_blank" rel="noopener" aria-label="Scan or tap to download Gym Log on the App Store">
				<img src="/app-qr.svg" alt="QR code linking to Gym Log on the App Store" width="180" height="180" />
				<span>Scan to download</span>
			</a>
		</div>
	</section>
</Layout>

<style>
	.hero {
		position: relative;
		padding: 4rem 0 6rem;
		text-align: center;
		overflow: hidden;
	}

	.hero-content {
		position: relative;
		z-index: 10;
		max-width: 820px;
		margin: 0 auto;
	}

	.hero-logo {
		display: block;
		width: 160px;
		height: 160px;
		margin: 0 auto 1.5rem;
		border-radius: 28px;
		box-shadow: 0 20px 40px -12px rgba(180, 83, 9, 0.35), 0 8px 16px -8px rgba(180, 83, 9, 0.2);
	}

	@media (min-width: 640px) {
		.hero-logo {
			width: 180px;
			height: 180px;
		}
	}

	.gradient-text {
		font-size: clamp(3rem, 8vw, 5rem);
		color: var(--primary-dark);
		margin-bottom: 1rem;
		letter-spacing: -0.05em;
	}

	.subtitle {
		font-size: 1.5rem;
		font-weight: 600;
		color: var(--text);
		margin-bottom: 1.5rem;
	}

	.description {
		font-size: 1.125rem;
		max-width: 600px;
		margin: 0 auto 2.5rem;
	}

	.hero-glow {
		display: none;
	}

	.features {
		padding: 4rem 0;
	}

	.section-header {
		text-align: center;
		margin-bottom: 3rem;
	}

	.divider {
		height: 4px;
		width: 64px;
		background: var(--primary);
		margin: 1rem auto;
		border-radius: 2px;
	}

	.feature-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 2rem;
	}

	.feature-card {
		background: var(--surface);
		padding: 2.5rem;
		border-radius: 1rem;
		border: 1px solid var(--border);
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.feature-card:hover {
		transform: translateY(-8px);
		border-color: var(--primary);
		box-shadow: 0 20px 25px -5px rgba(180, 83, 9, 0.1), 0 10px 10px -5px rgba(180, 83, 9, 0.04);
	}

	.feature-card .icon {
		font-size: 3rem;
		margin-bottom: 1.5rem;
	}

	.feature-card h3 {
		margin-bottom: 0.75rem;
		color: var(--primary-dark);
	}

	.feature-card p {
		margin-bottom: 0;
		font-size: 1rem;
		flex-grow: 1;
	}

	.appstore-btn {
		gap: 0.625rem;
	}

	.apple-logo {
		margin-top: -2px;
	}

	.download {
		padding: 2rem 0 4rem;
	}

	.download-card {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 2.5rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 1.5rem;
		padding: 3rem;
		box-shadow: 0 20px 40px -16px rgba(180, 83, 9, 0.18);
	}

	.download-text {
		flex: 1 1 320px;
	}

	.download-text h2 {
		margin-bottom: 0.5rem;
	}

	.download-text .divider {
		margin: 1rem 0 1.5rem;
	}

	.qr {
		flex: 0 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
	}

	.qr img {
		display: block;
		width: 180px;
		height: 180px;
		padding: 0.75rem;
		background: #ffffff;
		border: 1px solid var(--border);
		border-radius: 1rem;
		box-shadow: 0 8px 16px -8px rgba(180, 83, 9, 0.15);
	}

	.qr span {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--text-muted);
	}

	@media (max-width: 600px) {
		.download-card {
			padding: 2rem;
			justify-content: center;
			text-align: center;
		}

		.download-text .divider {
			margin: 1rem auto 1.5rem;
		}
	}
</style>
