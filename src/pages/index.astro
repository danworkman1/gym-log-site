---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="The simplest way to log your workouts and stay consistent.">
	<section class="hero">
		<div class="hero-content">
			<h1 class="gradient-text">Gym Log</h1>
			<p class="subtitle">Focus on your gains, not your screen.</p>
			<p class="description">Gym Log is a clean, minimal workout tracker built for lifters who want to spend more time lifting and less time tapping. Seamlessly integrated with Apple Health.</p>
			<div class="cta">
				<a href="#" class="btn">Coming Soon to App Store</a>
			</div>
		</div>
		<div class="hero-glow"></div>
	</section>

	<section class="features">
		<div class="section-header">
			<h2>Features</h2>
			<div class="divider"></div>
		</div>
		<div class="feature-grid">
			<div class="feature-card">
				<div class="icon">📝</div>
				<h3>Simple Logging</h3>
				<p>Quickly add exercises, sets, and reps without the friction of complex interfaces.</p>
			</div>
			<div class="feature-card">
				<div class="icon">🍎</div>
				<h3>Apple Health</h3>
				<p>Sync your workouts automatically and keep your fitness data in one place.</p>
			</div>
			<div class="feature-card">
				<div class="icon">📈</div>
				<h3>Progress Tracking</h3>
				<p>Visualize your journey with detailed history and personal record tracking.</p>
			</div>
			<div class="feature-card">
				<div class="icon">🛡️</div>
				<h3>Privacy First</h3>
				<p>Your data stays on your device and in your personal iCloud account. No tracking.</p>
			</div>
		</div>
	</section>
</Layout>

<style>
	.hero {
		position: relative;
		padding: 4rem 0 6rem;
		text-align: center;
		overflow: hidden;
	}

	.hero-content {
		position: relative;
		z-index: 10;
		max-width: 820px;
		margin: 0 auto;
	}

	.gradient-text {
		font-size: clamp(3rem, 8vw, 5rem);
		color: var(--primary-dark);
		margin-bottom: 1rem;
		letter-spacing: -0.05em;
	}

	.subtitle {
		font-size: 1.5rem;
		font-weight: 600;
		color: var(--text);
		margin-bottom: 1.5rem;
	}

	.description {
		font-size: 1.125rem;
		max-width: 600px;
		margin: 0 auto 2.5rem;
	}

	.hero-glow {
		display: none;
	}

	.features {
		padding: 4rem 0;
	}

	.section-header {
		text-align: center;
		margin-bottom: 3rem;
	}

	.divider {
		height: 4px;
		width: 64px;
		background: var(--primary);
		margin: 1rem auto;
		border-radius: 2px;
	}

	.feature-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 2rem;
	}

	.feature-card {
		background: var(--surface);
		padding: 2.5rem;
		border-radius: 1rem;
		border: 1px solid var(--border);
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.feature-card:hover {
		transform: translateY(-8px);
		border-color: var(--primary);
		box-shadow: 0 20px 25px -5px rgba(180, 83, 9, 0.1), 0 10px 10px -5px rgba(180, 83, 9, 0.04);
	}

	.feature-card .icon {
		font-size: 3rem;
		margin-bottom: 1.5rem;
	}

	.feature-card h3 {
		margin-bottom: 0.75rem;
		color: var(--primary-dark);
	}

	.feature-card p {
		margin-bottom: 0;
		font-size: 1rem;
		flex-grow: 1;
	}
</style>
