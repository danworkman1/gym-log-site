---
import Layout from '../layouts/Layout.astro';

const turnstileSiteKey = (Astro.locals as any).runtime?.env?.TURNSTILE_SITE_KEY;
---

<Layout title="Contact">
	<header class="page-header">
		<h1>Contact Us</h1>
		<p>Have a question or feedback? Send us a message below.</p>
	</header>

	<div class="contact-container">
		<form action="/api/contact" method="POST" id="contact-form" class="contact-form">
			<div class="form-group">
				<label for="name">Name</label>
				<input type="text" id="name" name="name" required maxlength="120" placeholder="Your Name">
			</div>

			<div class="form-group">
				<label for="email">Email</label>
				<input type="email" id="email" name="email" required maxlength="254" placeholder="your@email.com">
			</div>

			<div class="form-group">
				<label for="message">Message</label>
				<textarea id="message" name="message" required rows="5" maxlength="4000" placeholder="How can we help?"></textarea>
			</div>

			{turnstileSiteKey ? (
				<div 
					class="cf-turnstile" 
					data-sitekey={turnstileSiteKey}
					data-theme="light"
					data-appearance="interaction-only"
					data-action="contact"
				></div>
			) : (
				<p class="verification-warning">
					Contact verification is not configured.
				</p>
			)}

			<p id="contact-form-status" class="status-message" aria-live="polite"></p>

			<button type="submit" id="submit-btn" class="btn" disabled={!turnstileSiteKey}>
				Send Message
			</button>
		</form>

		<aside class="contact-info">
			<div class="info-card">
				<h3>Direct Email</h3>
				<p><strong>support@gym-log-app.com</strong></p>
				<p class="note">Our team typically responds within 24-48 hours.</p>
			</div>
			<div class="info-card">
				<h3>Office Hours</h3>
				<p>Monday — Friday</p>
				<p>9:00 AM — 5:00 PM EST</p>
			</div>
		</aside>
	</div>
</Layout>

<style>
	.page-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.contact-container {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 360px;
		gap: 4rem;
		align-items: start;
	}

	@media (max-width: 800px) {
		.contact-container {
			grid-template-columns: 1fr;
			gap: 3rem;
		}
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		background: var(--surface);
		padding: 2.5rem;
		border-radius: 1rem;
		border: 1px solid var(--border);
		box-shadow: 0 4px 6px -1px rgba(180, 83, 9, 0.05);
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	label {
		font-weight: 700;
		font-size: 0.85rem;
		color: var(--text-muted);
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	input, textarea {
		padding: 1rem;
		border: 1px solid var(--border);
		border-radius: 0.75rem;
		background-color: #ffffff;
		color: var(--text);
		font-family: inherit;
		font-size: 1rem;
		transition: all 0.2s ease;
	}

	input:focus, textarea:focus {
		outline: none;
		border-color: var(--primary);
		box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.1);
	}

	.contact-info {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.info-card {
		background: var(--surface);
		padding: 2rem;
		border-radius: 1rem;
		border: 1px solid var(--border);
	}

	.info-card h3 {
		font-size: 1.1rem;
		margin-bottom: 0.75rem;
		color: var(--primary-dark);
	}

	.info-card p {
		margin-bottom: 0;
		font-size: 0.95rem;
	}

	.note {
		font-size: 0.8rem;
		margin-top: 0.5rem;
		font-style: italic;
	}

	.verification-warning {
		padding: 1rem;
		background: #fffbeb;
		border: 1px solid #fde68a;
		border-radius: 0.5rem;
		color: #92400e;
		font-size: 0.9rem;
		font-weight: 500;
	}

	.status-message {
		min-height: 1.5rem;
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--primary-dark);
	}
</style>

{turnstileSiteKey && (
	<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

<script>
	const form = document.querySelector<HTMLFormElement>('#contact-form');
	const status = document.querySelector<HTMLParagraphElement>('#contact-form-status');
	const submitBtn = document.querySelector<HTMLButtonElement>('#submit-btn');

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		
		if (!status || !submitBtn) {
			form.submit();
			return;
		}

		status.textContent = 'Sending message...';
		status.style.color = 'var(--text-muted)';
		submitBtn.disabled = true;

		try {
			const formData = new FormData(form);
			const response = await fetch(form.action, {
				method: 'POST',
				headers: {
					'Accept': 'application/json',
					'X-Requested-With': 'fetch'
				},
				body: formData
			});

			const result = await response.json() as { message: string };

			status.textContent = result.message;
			
			if (response.ok) {
				status.style.color = 'var(--success)';
				form.reset();
			} else {
				status.style.color = '#ef4444';
			}
		} catch (err) {
			status.textContent = 'Something went wrong. Please try again.';
			status.style.color = '#ef4444';
		} finally {
			submitBtn.disabled = false;
			// @ts-ignore
			window.turnstile?.reset();
		}
	});
</script>
